APP_NAME=CareerPilot API
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:5173

# Keep true for local demo without external model calls.
LLM_DRY_RUN=true
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Optional cross-check model for Week9/W10 QualityGate.
JUDGE_DRY_RUN=true
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4.1-mini
JUDGE_BASE_URL=https://api.openai.com/v1
JUDGE_API_KEY=

# Optional production boundary. Leave API_ACCESS_TOKEN empty for local demos.
API_ACCESS_TOKEN=
RATE_LIMIT_REQUESTS_PER_MINUTE=180
SECURITY_HEADERS_ENABLED=true
